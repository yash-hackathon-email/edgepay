<?xml version="1.0" encoding="utf-8"?>
<!--
    EdgePay Home Screen Widget Layout (v3)
    Safety: Uses only RemoteViews-compatible components.
    Design: Premium glass-card with strong status indicators.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/home_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_home_bg"
    android:padding="16dp">

    <!-- ── Header: Logo + Service Status ── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ EdgePay"
            android:textColor="#0A84FF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/widget_pill_bg"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/home_widget_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Active"
                android:textColor="#30D158"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/home_widget_refresh_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginLeft="10dp"
                android:text="↻"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:gravity="center"
                android:background="@drawable/widget_dismiss_bg" />
        </LinearLayout>
    </RelativeLayout>

    <!-- ── Body: Last Transaction ── -->
    <TextView
        android:id="@+id/home_widget_type_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No payments yet"
        android:textColor="#99EBEBF5"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/home_widget_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹ —"
        android:textColor="#30D158"
        android:textSize="34sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/home_widget_sender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Waiting for transactions..."
        android:textColor="#EBEBF5"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/home_widget_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#60EBEBF5"
        android:textSize="10sp"
        android:layout_marginTop="4dp" />

    <!-- ── Footer Spacer ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ── Actions ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/home_widget_toggle_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="▶ Start Monitor"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/widget_toggle_btn_bg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
            android:text="Settings ›"
            android:textColor="#800A84FF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
