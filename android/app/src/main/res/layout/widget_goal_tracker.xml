<?xml version="1.0" encoding="utf-8"?>
<!--
    EdgePay Goal Tracker Widget (2×2)
    Displays progress toward monthly budget goal.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/goal_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_goal_bg"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Progress Circle (Dynamic Bitmap) -->
        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/goal_widget_circle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/widget_preview_bg" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/goal_widget_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="used"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Labels -->
        <TextView
            android:id="@+id/goal_widget_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly Goal"
            android:textColor="#0A84FF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/goal_widget_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹ 0 / ₹ 0"
            android:textColor="#EBEBF5"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</FrameLayout>
